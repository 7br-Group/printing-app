   "source": [
    "# @title بناء APK (30-40 دقيقة ⏳)\n",
    "\n",
    "print('🔨 جاري بناء APK...')\n",
    "print('⏳ هتاخد 30-40 دقيقة. روح اشرب شاي واستنى.')\n",
    "print('=' * 50)\n",
    "\n",
    "%cd /content/printing-app/mobile_app\n",
    "\n",
    "# Override buildozer spec to use our settings\n",
    "spec = '''[app]\n",
    "title = \\u0646\\u0638\\u0627\\u0645 \\u0627\\u0644\\u0645\\u0637\\u0628\\u0639\\u0629\n",
    "package.name = printingapp\n",
    "package.domain = com.printingapp\n",
    "source.dir = .\n",
    "source.include_exts = py,png,jpg,kv,atlas,txt,js,json,html,css,xml,ico,svg,db\n",
    "version = 1.0.0\n",
    "requirements = python3,kivy,flask,requests,pyjnius,waitress\n",
    "presplash.filename = splash.png\n",
    "icon.filename = icon.png\n",
    "orientation = portrait\n",
    "android.api = 34\n",
    "android.minapi = 26\n",
    "android.ndk = 27c\n",
    "android.sdk = 34\n",
    "android.bootstrap = sdl2\n",
    "android.permissions = INTERNET,ACCESS_NETWORK_STATE,ACCESS_WIFI_STATE,POST_NOTIFICATIONS\n",
    "android.accept_sdk_license = True\n",
    "android.wakelock = True\n",
    "'''\n",
    "\n",
    "with open('buildozer.spec', 'w', encoding='utf-8') as f:\n",
    "    f.write(spec)\n",
    "\n",
    "# Run Buildozer\n",
    "result = os.system('buildozer android debug 2>&1')\n",
    "\n",
    "if result == 0:\n",
    "    print('\\n✅✅✅ BUILD SUCCESS! ✅✅✅')\n",
    "else:\n",
    "    print('\\n❌❌❌ BUILD FAILED ❌❌❌')\n",
    "    print('راجع output فوق عشان تشوف الخطأ')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title تحميل APK\n",
    "import glob\n",
    "from google.colab import files\n",
    "\n",
    "apks = glob.glob('/content/printing-app/mobile_app/bin/*.apk')\n",
    "if not apks:\n",
    "    apks = glob.glob('/content/printing-app/mobile_app/bin/*/*.apk')\n",
    "\n",
    "if apks:\n",
    "    apk_path = apks[0]\n",
    "    size_mb = os.path.getsize(apk_path) / (1024 * 1024)\n",
    "    print(f'📱 APK: {apk_path}')\n",
    "    print(f'📦 الحجم: {size_mb:.1f} MB')\n",
    "    print('\\n⬇️ اضغط على زر التحميل...')\n",
    "    files.download(apk_path)\n",
    "else:\n",
    "    print('❌ ما لقيتش APK. البناء فشل.')\n",
    "    print('شوف output اللي فوق عشان تعرف الخطأ.')"
  }
