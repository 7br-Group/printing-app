   "source": [
    "# @title إعداد البيئة\n",
    "import os, sys, subprocess, shutil, time, zipfile, glob\n",
    "from IPython.display import clear_output\n",
    "\n",
    "print('📦 جاري تحميل الأدوات...')\n",
    "\n",
    "# Install system deps\n",
    "os.system('apt-get update -qq && apt-get install -y -qq wget unzip git openjdk-17-jdk python3-pip autoconf libtool pkg-config zlib1g-dev libncurses5-dev libncursesw5-dev libtinfo5 cmake 2>&1 | tail -5')\n",
    "\n",
    "# Install Buildozer\n",
    "os.system('pip install -q buildozer Cython 2>&1 | tail -3')\n",
    "\n",
    "print('✅ تم تجهيز البيئة')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title تحميل المشروع\n",
    "import zipfile, requests, io\n",
    "\n",
    "print('📥 جاري تحميل المشروع...')\n",
    "\n",
    "url = 'https://github.com/7br-Group/printing-app/archive/refs/heads/master.zip'\n",
    "r = requests.get(url, stream=True)\n",
    "z = zipfile.ZipFile(io.BytesIO(r.content))\n",
    "z.extractall('/content/')\n",
    "\n",
    "# Rename folder\n",
    "os.rename('/content/printing-app-master', '/content/printing-app')\n",
    "\n",
    "print('✅ تم تحميل المشروع')\n",
    "print(f'\\nالمجلدات: {os.listdir(\"/content/printing-app\")}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# @title تجهيز ملفات الموبايل\n",
    "import shutil, os\n",
    "\n",
    "print('📁 تجهيز ملفات APK...')\n",
    "\n",
    "root = '/content/printing-app'\n",
    "mobile = os.path.join(root, 'mobile_app')\n",
    "\n",
    "# Copy web app\n",
    "shutil.copytree(os.path.join(root, 'web_app'), os.path.join(mobile, 'web_app'))\n",
    "\n",
    "# Copy WhatsApp server\n",
    "shutil.copytree(os.path.join(root, 'whatsapp_server'), os.path.join(mobile, 'whatsapp_server'))\n",
    "\n",
    "# Copy database\n",
    "db_path = os.path.join(root, 'printing_app.db')\n",
    "if os.path.exists(db_path):\n",
    "    shutil.copy2(db_path, os.path.join(mobile, 'printing_app.db'))\n",
    "\n",
    "# Install Node.js deps and compile WhatsApp server with pkg\n",
    "%cd /content/printing-app/mobile_app/whatsapp_server\n",
    "os.system('npm install 2>&1 | tail -3')\n",
    "os.system('npm install -g pkg 2>&1 | tail -3')\n",
    "os.system('npx pkg server.js --target node18-linux-arm64 --output whatsapp-server 2>&1 | tail -5')\n",
    "\n",
    "# Generate icons\n",
    "%cd /content/printing-app/mobile_app\n",
    "\n",
    "import struct, zlib\n",
    "def make_png(w, h, r, g, b):\n",
    "    raw = b''\n",
    "    for y in range(h):\n",
    "        raw += b'\\x00'\n",
    "        for x in range(w):\n",
    "            cy = y / h\n",
    "            raw += struct.pack('BBBB', int(r * (1-cy*0.3)), int(g * (1-cy*0.3)), int(b * (1-cy*0.3)), 255)\n",
    "    comp = zlib.compress(raw)\n",
    "    sig = b'\\x89PNG\\r\\n\\x1a\\n'\n",
    "    ihdr = struct.pack('>IIBBBBB', w, h, 8, 6, 0, 0, 0)\n",
    "    def chunk(t, d):\n",
    "        c = t + d\n",
    "        return struct.pack('>I', len(d)) + c + struct.pack('>I', zlib.crc32(c) & 0xffffffff)\n",
    "    return sig + chunk(b'IHDR', ihdr) + chunk(b'IDAT', comp) + chunk(b'IEND', b'')\n",
    "\n",
    "for name, sz in [('splash.png', 512), ('icon.png', 192)]:\n",
    "    with open(name, 'wb') as f:\n",
    "        f.write(make_png(sz, sz, 59, 130, 246))\n",
    "\n",
    "print('✅ تم تجهيز الملفات')"
   ]
  },
  {
   "cell_type": "code",
