{
  "builds": [
    {
      "src": "web_app/app.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "web_app/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "web_app/app.py"
    }
  ],
  "env": {
    "SECRET_KEY": "change-this-to-a-random-secret-key"
  }
}
